    <string name="settings_info">Info</string>
    <string name="settings_expand">Expand</string>
    <string name="settings_info_asr_section">Speech recognition endpoint. Used for live mic/internal/file and for history reprocess.</string>
    <string name="settings_info_llm_section">Translation endpoint. Skipped entirely when ASR-only mode is on.</string>
    <string name="settings_info_asr_url">Default: if a path already exists after /v1/, use as-is; otherwise append:\n• OpenAiTranscriptions → /v1/audio/transcriptions\n• ChatCompletionsAudio → /v1/chat/completions\n\nWith “Full URL” on: no path is appended.</string>
    <string name="settings_info_llm_url">Default: if a path already exists after /v1/, use as-is; otherwise append /v1/chat/completions.\n\nWith “Full URL” on: request exactly the URL you typed.</string>
    <string name="settings_info_full_url">When on, the API URL is used exactly as typed (no /v1/… append).</string>
    <string name="settings_info_api_key">Provider secret for this service. Stored in app DataStore (not encrypted). Restore-defaults buttons do not clear the key.</string>
    <string name="settings_info_model">Model id sent in the request body (e.g. whisper-1, gpt-4o-mini). Must match what your gateway accepts.</string>
    <string name="settings_info_asr_style">• OpenAiTranscriptions — multipart WAV (classic Whisper)\n• ChatCompletionsAudio — chat + base64 input_audio (e.g. MIMO)\n\nAffects request body only, not URL resolution.</string>
    <string name="settings_info_asr_auth">• Bearer — Authorization: Bearer &lt;key&gt;\n• ApiKeyHeader — api-key: &lt;key&gt; (e.g. Xiaomi MIMO)</string>
    <string name="settings_info_llm_auth">Having an API key ≠ ApiKeyHeader.\n\n• Bearer (DeepSeek / OpenAI, etc.) — Authorization: Bearer &lt;key&gt;\n• ApiKeyHeader — header name is api-key\n\nUse Bearer for DeepSeek.</string>
    <string name="settings_info_thinking">Thinking switch (after messages):\n• Enabled — \"thinking\":{\"type\":\"enabled\"} + effort field\n• Disabled — \"thinking\":{\"type\":\"disabled\"}\n\nDefault is Enabled.\nResponse thinking / reasoning_content is ignored; only delta.content is used; &lt;think&gt; tags are stripped.</string>
    <string name="settings_info_reasoning_effort">When thinking is Enabled, send effort:\n• High — ordinary translate (default)\n• Max — harder tasks\n\nCompat: low/medium → high, xhigh → max.\nOpenAI body: \"reasoning_effort\":\"high|max\"\nAnthropic body: \"output_config\":{\"effort\":\"high|max\"}</string>
    <string name="settings_info_reasoning_effort_style">Where to put effort when thinking is Enabled:\n• OpenAi — top-level reasoning_effort (DeepSeek / OpenAI-compat)\n• Anthropic — output_config.effort</string>
    <string name="settings_info_system_prompt">System message for live / offline translation.\n\nPlaceholders:\n• {{from}} — input language\n• {{to}} — output language\n• {{glossary}} — glossary lines (empty if none)\n\nDefault: translation-only, skip fillers, light ASR repair, glossary first.</string>
    <string name="settings_info_user_prompt">User message for each translation request.\n\nPlaceholders:\n• {{from}} / {{to}} — languages\n• {{history}} — previous turns for context\n• {{text}} — current source utterance (required)\n\nMust include {{text}} so the model receives the sentence to translate.</string>
    <string name="settings_info_title_system_prompt">System message when generating a session title after enough turns.</string>
    <string name="settings_info_title_user_prompt">User message for session title generation.\n\nPlaceholder:\n• {{dialogue}} — numbered source → translation sample turns</string>
    <string name="settings_prompt_section">LLM prompts</string>
    <string name="settings_prompt_section_info">All chat prompts used by the app (translation system/user + session title). Edit freely; blank fields fall back to built-in English defaults on save.</string>
    <string name="settings_info_languages">Languages sent to ASR / LLM (not the app UI language).\nUse short codes such as en, zh, ja, or names your API accepts.</string>
    <string name="settings_info_input_lang">Source language for ASR and LLM (e.g. en).</string>
    <string name="settings_info_output_lang">Target language for translation (e.g. zh). Ignored in ASR-only mode.</string>
    <string name="settings_info_vad">Silero DNN VAD + utterance rules:\n• Silence ms — end-of-utterance silence\n• Max utterance ms — force cut length\n• Min utterance ms — drop short clips\n• Silero mode — model confidence (NORMAL / AGGRESSIVE / VERY_AGGRESSIVE)\n• Context window N — LLM history turns</string>
    <string name="settings_info_silence_ms">How long continuous silence ends an utterance (ms). Typical 300–800.</string>
    <string name="settings_info_max_utt_ms">Force-cut length if speech never pauses (ms). Lower = faster latency, more cuts.</string>
    <string name="settings_info_min_utt_ms">Drop clips shorter than this (ms) to reduce noise false triggers.</string>
    <string name="settings_info_energy">RMS energy gate for speech vs silence. Raise in noisy rooms; lower if soft speech is missed.</string>
    <string name="settings_info_silero_mode">Silero score threshold mode:\n• NORMAL — balanced (default)\n• AGGRESSIVE — fewer false speech hits\n• VERY_AGGRESSIVE — strictest; may miss soft speech\n\nFrame size is fixed at 512 samples @ 16 kHz (~32 ms).</string>
    <string name="settings_info_context_n">How many previous EN/ZH pairs are sent as LLM context for terminology consistency.</string>
    <string name="settings_info_overlay">Floating caption over other apps:\n• Content mode / layout / font size\n• Size, colors, opacity\n• Stack order (translation vs source on top)\n\nLock/unlock from the recording notification; unlocked = drag, locked = touch-through.</string>
    <string name="settings_info_overlay_font">Floating overlay text size in sp (10–48).</string>
    <string name="settings_info_live_font">Home bilingual list text size in sp (10–48).</string>
    <string name="settings_info_overlay_size">Max width/height in dp. Content scrolls if taller than max height.</string>
    <string name="settings_info_overlay_color">Hex #RGB / #RRGGBB / #AARRGGBB. Background alpha is controlled by opacity % separately.</string>
    <string name="settings_info_pipeline">History reprocess &amp; offline packing:\n• VAD batch — sentences packed per offline ASR call (default 70)\n• Title threshold — LLM title after N turns\n• Network retries — per ASR/LLM item\n• Translation cache — in-session cache size\n\nReprocess soft-skips failed batches/sentences and still saves partial results.\nLive file import uses the VAD + timeline pipeline (not this offline packer).</string>
    <string name="settings_info_offline_vad_batch">Offline/reprocess only: how many VAD sentences are packed into one ASR request.</string>
    <string name="settings_info_title_threshold">After this many completed turns, try LLM session title (live &amp; file import).</string>
    <string name="settings_info_max_attempts">Automatic retries per ASR/LLM request (1–10) with exponential backoff.</string>
    <string name="settings_info_translation_cache">In-session cache of identical source→translation pairs. Cleared when a new session starts.</string>
    <string name="settings_info_keep_screen_on">Keeps the Live screen awake while this option is on.</string>
    <string name="settings_info_immersive">Hides status/navigation bars on the Live screen (swipe edge to show briefly). Full bilingual-only immersive is entered via the Immersive button on the home Live page.</string>
