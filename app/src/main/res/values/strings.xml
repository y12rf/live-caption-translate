    <string name="settings_title_user_prompt_title">Title user prompt</string>
    <string name="settings_full_url_title">Full URL</string>
    <string name="settings_pipeline">Pipeline / offline</string>
    <string name="settings_pipeline_info">History reprocess &amp; offline packing:\n• VAD batch size — sentences packed per ASR call (default 70)\n• Title threshold — LLM title after N turns\n• Network retries — ASR/LLM auto retries\n• Translation cache — session cache size\n\nFailed ASR/LLM items soft-skip; partial sessions are still saved.\nLive file import uses energy VAD + timeline (recording pipeline).</string>
    <string name="settings_offline_vad_batch">Offline VAD batch (sentences / ASR)</string>
    <string name="settings_title_threshold">Title after N turns</string>
